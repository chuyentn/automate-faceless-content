# CẤU HÌNH API KEYS CHO AUTO-BLOGGER
# Chọn 1 trong các model bên dưới và điền Key vào. Model nào không dùng thì bỏ trống.

# 1. GOOGLE GEMINI (Khuyên dùng: Miễn phí, thông minh)
# Nhận API Key tại: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# 2. OPENAI (ChatGPT - Trả phí nhưng chất lượng cao nhất)
# Nhận API Key tại: https://platform.openai.com/
OPENAI_API_KEY=

# 3. GROQ (Miễn phí 100%, Siêu tốc độ, dùng model Llama 3)
# Nhận API Key tại: https://console.groq.com/
GROQ_API_KEY=

# 4. OPENROUTER (Tổng hợp hàng trăm model AI miễn phí & trả phí)
# Nhận API Key tại: https://openrouter.ai/
OPENROUTER_API_KEY=

# --- LỰA CHỌN MODEL MẶC ĐỊNH ---
# Gõ tên model bạn muốn dùng vào đây (gemini, openai, groq, openrouter)
ACTIVE_MODEL=gemini

# --- LINK AFFILIATE CỦA BẠN ---
MY_AFFILIATE_LINK=https://syllaby.io/?via=victorchuyen68

# --- TỰ ĐỘNG ĐĂNG BÀI LÊN TELEGRAM (Tùy chọn) ---
# Cách lấy Token: Lên Telegram tìm @BotFather -> /newbot -> Copy Token
TELEGRAM_BOT_TOKEN=
# Cách lấy Chat ID: Thêm bot vào Kênh/Group của bạn, sau đó gửi 1 tin nhắn vào kênh. Rồi vào https://api.telegram.org/bot<TOKEN_CỦA_BẠN>/getUpdates để lấy phần "chat":{"id": -100xxxxx}
TELEGRAM_CHAT_ID=

# --- FIREBASE CONFIGURATION ---
# Tạo project tại https://firebase.google.com/ và lấy cấu hình trong phần Project Settings
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
